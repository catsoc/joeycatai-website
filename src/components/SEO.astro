---
import { SITE } from '@/site.config';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  article?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  robots?: string;
  lang?: 'zh-TW' | 'en';
}

const {
  title,
  description = SITE.description,
  image,
  imageWidth,
  imageHeight,
  imageType,
  article = false,
  pubDate,
  updatedDate,
  tags = [],
  author = SITE.author,
  robots = 'index,follow',
  lang = 'zh-TW',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);

const localeMap: Record<string, string> = { 'zh-TW': 'zh_TW', en: 'en_US' };
const ogLocale = localeMap[lang] ?? 'zh_TW';

const isDefaultImage = !image;
const resolvedImage = image ?? '/og-default.png';
const ogImage = resolvedImage.startsWith('http')
  ? resolvedImage
  : new URL(resolvedImage, SITE.url).toString();
const ogWidth = isDefaultImage ? 1200 : imageWidth;
const ogHeight = isDefaultImage ? 630 : imageHeight;
const ogType = isDefaultImage ? 'image/png' : imageType;

const fullTitle = title.includes(SITE.name) ? title : `${title} · ${SITE.name}`;
---

<!-- Primary -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph（Facebook、Instagram、Threads 共用） -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={fullTitle} />
{ogWidth && <meta property="og:image:width" content={String(ogWidth)} />}
{ogHeight && <meta property="og:image:height" content={String(ogHeight)} />}
{ogType && <meta property="og:image:type" content={ogType} />}
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={ogLocale} />

<!-- Article 專屬 Open Graph -->
{article && (
  <>
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={author} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- Twitter / X -->
<meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
<meta name="twitter:site" content={SITE.twitterHandle} />
<meta name="twitter:creator" content={SITE.twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Feed -->
<link rel="alternate" type="application/rss+xml" title={`${SITE.name} Blog`} href="/rss.xml" />
