---
import { SITE } from '@/site.config';
import IconGitHub from './icons/IconGitHub.astro';
import IconTwitter from './icons/IconTwitter.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
import IconRSS from './icons/IconRSS.astro';

const year = new Date().getFullYear();

const iconById = {
  github: IconGitHub,
  twitter: IconTwitter,
  linkedin: IconLinkedIn,
} as const;

const socials = SITE.socials.map((social) => ({
  ...social,
  Icon: iconById[social.id],
}));
---

<footer class="border-t border-slate-200 dark:border-slate-800 mt-auto">
  <div class="container-base py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500 dark:text-slate-500">
        &copy; {year} joeycatai · Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent-600 dark:text-accent-400 hover:underline"
        >Astro</a>
        &amp; Cloudflare Pages
      </p>

      <div class="flex items-center gap-3">
        {socials.map(({ label, href, Icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
          >
            <Icon />
          </a>
        ))}
        <a
          href="/rss.xml"
          aria-label="RSS Feed"
          class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
        >
          <IconRSS />
        </a>
      </div>
    </div>
  </div>
</footer>
