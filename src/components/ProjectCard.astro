---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import StatusBadge from './StatusBadge.astro';
import IconGitHub from './icons/IconGitHub.astro';

export interface Props {
  title: string;
  description: string;
  slug: string;
  tags?: string[];
  heroImage?: ImageMetadata;
  github?: string;
  demo?: string;
  status?: 'active' | 'completed' | 'archived';
  featured?: boolean;
}

const { title, description, slug, tags = [], heroImage, github, demo, status = 'completed', featured = false } = Astro.props;
---

<div class={`card group flex flex-col gap-4 ${featured ? 'ring-1 ring-accent-200 dark:ring-accent-800' : ''}`}>
  {heroImage && (
    <a href={`/projects/${slug}`}>
      <Image
        src={heroImage}
        alt={title}
        class="w-full aspect-video object-cover rounded-lg"
        loading="lazy"
      />
    </a>
  )}
  <div class="flex flex-col gap-2 flex-1">
    <div class="flex flex-wrap items-center gap-1.5">
      <StatusBadge status={status} />
      {featured && (
        <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
          精選
        </span>
      )}
    </div>

    <a href={`/projects/${slug}`} class="group">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
        {title}
      </h2>
    </a>

    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 flex-1">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <!-- Links -->
    <div class="flex items-center gap-3 mt-2">
      {demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-accent-600 dark:text-accent-400 hover:underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Demo
        </a>
      )}
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100"
        >
          <IconGitHub class="w-3.5 h-3.5" />
          GitHub
        </a>
      )}
      <a
        href={`/projects/${slug}`}
        class="inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 ml-auto"
      >
        詳細介紹 →
      </a>
    </div>
  </div>
</div>
