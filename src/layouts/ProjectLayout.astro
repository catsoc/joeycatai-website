---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import IconGitHub from '@/components/icons/IconGitHub.astro';
import { SITE } from '@/site.config';
import { toTagSlug } from '@/lib/tags';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  github?: string;
  demo?: string;
  status?: 'active' | 'completed' | 'archived';
}

const { title, description, pubDate, heroImage, tags = [], github, demo, status = 'completed' } = Astro.props;

const resolvedHero = heroImage ? await getImage({ src: heroImage }) : undefined;

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description,
  datePublished: pubDate.toISOString(),
  creator: { '@type': 'Person', name: SITE.author, url: SITE.url },
  url: new URL(Astro.url.pathname, SITE.url),
};
---

<BaseLayout
  title={title}
  description={description}
  image={resolvedHero?.src}
  imageWidth={heroImage?.width}
  imageHeight={heroImage?.height}
  imageType={heroImage ? `image/${heroImage.format}` : undefined}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(projectSchema)} />

  <article class="container-base py-12">
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-accent-600 dark:hover:text-accent-400 mb-8 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      所有專案
    </a>

    <header class="mb-8">
      {heroImage && (
        <Image
          src={heroImage}
          alt={title}
          class="w-full aspect-[2/1] object-cover rounded-xl mb-8 shadow-md"
        />
      )}
      <div class="flex flex-wrap gap-2 mb-4">
        <StatusBadge status={status} />
        {tags.map((tag) => (
          <a href={`/tags/${toTagSlug(tag)}`} class="tag hover:opacity-80 transition-opacity">{tag}</a>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-100 mb-4">
        {title}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">{description}</p>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-3">
        {demo && (
          <a href={demo} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            查看 Demo
          </a>
        )}
        {github && (
          <a href={github} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <IconGitHub class="w-4 h-4" />
            GitHub
          </a>
        )}
      </div>

      <div class="mt-4 text-sm text-slate-500 dark:text-slate-500">
        <FormattedDate date={pubDate} />
      </div>
    </header>

    <hr class="border-slate-200 dark:border-slate-700 mb-8" />

    <div class="prose-custom">
      <slot />
    </div>
  </article>
</BaseLayout>
